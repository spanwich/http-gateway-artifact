/* EverParse Scale Test: 4 rules */

#define MAX_RATE 50
#define DEAD_HASH 0xDEADDEADul

entrypoint
typedef struct _ScaleTest4
{
    /* Rule 0 */
    UINT32 r0_path_hash;
    UINT8  r0_method;
    UINT8  r0_min_role;

    /* Rule 1 */
    UINT32 r1_path_hash;
    UINT8  r1_method;
    UINT8  r1_min_role;

    /* Rule 2 */
    UINT32 r2_path_hash;
    UINT8  r2_method;
    UINT8  r2_min_role;

    /* Rule 3 */
    UINT32 r3_path_hash;
    UINT8  r3_method;
    UINT8  r3_min_role;

    /* Request */
    UINT32 req_path_hash;
    UINT8  req_method;
    UINT8  auth_state;

    /* Rate limit (CNF) */
    UINT8  rate_count;
    UINT8  _rate_ok { rate_count < MAX_RATE };

    /* Access control (DNF) */
    UINT8  _access_ok
    {
        (r0_path_hash == req_path_hash && r0_method == req_method && auth_state >= r0_min_role) ||
        (r1_path_hash == req_path_hash && r1_method == req_method && auth_state >= r1_min_role) ||
        (r2_path_hash == req_path_hash && r2_method == req_method && auth_state >= r2_min_role) ||
        (r3_path_hash == req_path_hash && r3_method == req_method && auth_state >= r3_min_role)
    };
} ScaleTest4;
