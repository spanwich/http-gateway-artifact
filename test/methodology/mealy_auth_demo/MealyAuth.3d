/*
 * EverParse Mealy Machine Authentication Demo
 *
 * Three request validators, one per permitted request type.
 * The glue code dispatches to the correct validator based on
 * (path_hash, method) from the raw request. Each validator
 * enforces auth state, rate limit, and request-specific constraints.
 *
 * Architecture:
 *   - Glue code prepends [auth_state, rate_count] to request data
 *   - Calls the appropriate validator
 *   - EverParse returns accept/reject (F*-verified)
 *   - State only advances on successful app-level outcomes
 *
 * Deny-by-default: unknown (path, method) combos have no validator.
 */

#define AUTH_UNAUTH 0
#define AUTH_OK     1

#define METHOD_GET  1
#define METHOD_POST 2

#define PATH_LOGIN  0x11111111ul
#define PATH_LOGOUT 0x22222222ul
#define PATH_STATUS 0x33333333ul

#define MAX_RATE    50

/*
 * LoginRequest: POST /login
 *
 * Allowed in ANY auth state (re-login permitted).
 * Rate limit enforced. Credential lengths bounded.
 *
 * Buffer layout:
 *   [auth_state:1][rate_count:1][path_hash:4][method:1]
 *   [_check:1]
 *   [username_len:1][username:N][password_len:1][password:M]
 *
 * Total: 8 + 1 + username_len + 1 + password_len bytes
 */
entrypoint
typedef struct _LoginRequest
{
    UINT8  auth_state;
    UINT8  rate_count;
    UINT32 path_hash;
    UINT8  method;
    UINT8  _check
    {
        path_hash == PATH_LOGIN &&
        method == METHOD_POST &&
        rate_count < MAX_RATE
    };
    UINT8  username_len { username_len >= 1 && username_len <= 32 };
    UINT8  username[username_len];
    UINT8  password_len { password_len >= 1 && password_len <= 64 };
    UINT8  password[password_len];
} LoginRequest;

/*
 * LogoutRequest: POST /logout
 *
 * Requires AUTH_OK state. No body.
 *
 * Buffer layout:
 *   [auth_state:1][rate_count:1][path_hash:4][method:1][_check:1]
 *
 * Total: 8 bytes
 */
entrypoint
typedef struct _LogoutRequest
{
    UINT8  auth_state;
    UINT8  rate_count;
    UINT32 path_hash;
    UINT8  method;
    UINT8  _check
    {
        path_hash == PATH_LOGOUT &&
        method == METHOD_POST &&
        auth_state == AUTH_OK &&
        rate_count < MAX_RATE
    };
} LogoutRequest;

/*
 * StatusRequest: GET /status
 *
 * Requires AUTH_OK state. No body.
 *
 * Buffer layout:
 *   [auth_state:1][rate_count:1][path_hash:4][method:1][_check:1]
 *
 * Total: 8 bytes
 */
entrypoint
typedef struct _StatusRequest
{
    UINT8  auth_state;
    UINT8  rate_count;
    UINT32 path_hash;
    UINT8  method;
    UINT8  _check
    {
        path_hash == PATH_STATUS &&
        method == METHOD_GET &&
        auth_state == AUTH_OK &&
        rate_count < MAX_RATE
    };
} StatusRequest;
