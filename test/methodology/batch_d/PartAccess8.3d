/* Partition Access Validator: 8 rules, access-only (no rate constraint).
 *
 * Each partition validator checks K=8 rules against a single request.
 * The universal constraint (rate limit) is checked separately by UnivRate.
 * Buffer: K*6 + 4 + 1 + 1 + 1 = 55 bytes.
 */

entrypoint
typedef struct _PartAccess8
{
    /* Rule 0 */
    UINT32 r0_path_hash;
    UINT8  r0_method;
    UINT8  r0_min_role;

    /* Rule 1 */
    UINT32 r1_path_hash;
    UINT8  r1_method;
    UINT8  r1_min_role;

    /* Rule 2 */
    UINT32 r2_path_hash;
    UINT8  r2_method;
    UINT8  r2_min_role;

    /* Rule 3 */
    UINT32 r3_path_hash;
    UINT8  r3_method;
    UINT8  r3_min_role;

    /* Rule 4 */
    UINT32 r4_path_hash;
    UINT8  r4_method;
    UINT8  r4_min_role;

    /* Rule 5 */
    UINT32 r5_path_hash;
    UINT8  r5_method;
    UINT8  r5_min_role;

    /* Rule 6 */
    UINT32 r6_path_hash;
    UINT8  r6_method;
    UINT8  r6_min_role;

    /* Rule 7 */
    UINT32 r7_path_hash;
    UINT8  r7_method;
    UINT8  r7_min_role;

    /* Request */
    UINT32 req_path_hash;
    UINT8  req_method;
    UINT8  auth_state;

    /* Access control (DNF) */
    UINT8  _access_ok
    {
        (r0_path_hash == req_path_hash && r0_method == req_method && auth_state >= r0_min_role) ||
        (r1_path_hash == req_path_hash && r1_method == req_method && auth_state >= r1_min_role) ||
        (r2_path_hash == req_path_hash && r2_method == req_method && auth_state >= r2_min_role) ||
        (r3_path_hash == req_path_hash && r3_method == req_method && auth_state >= r3_min_role) ||
        (r4_path_hash == req_path_hash && r4_method == req_method && auth_state >= r4_min_role) ||
        (r5_path_hash == req_path_hash && r5_method == req_method && auth_state >= r5_min_role) ||
        (r6_path_hash == req_path_hash && r6_method == req_method && auth_state >= r6_min_role) ||
        (r7_path_hash == req_path_hash && r7_method == req_method && auth_state >= r7_min_role)
    };
} PartAccess8;
